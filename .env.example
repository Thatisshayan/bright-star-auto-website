# Copy to .env and fill in real values. Never commit .env.

# Google Maps proxy (used by client/src/components/Map.tsx, currently unused
# by any page — Footer.tsx uses a plain iframe embed instead — and by
# GoogleReviewsWidget.tsx to pull live reviews).
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev

# Bright Star Auto's Google Place ID, for the live reviews widget
# (client/src/components/GoogleReviewsWidget.tsx). Find it at
# https://developers.google.com/maps/documentation/places/web-service/place-id
# Without this set, the widget silently doesn't render — no broken UI.
VITE_GOOGLE_PLACE_ID=

# Cloudflare Web Analytics (lightweight, privacy-friendly)
# Get token from: https://dash.cloudflare.com → Web Analytics → Add site
# Free tier includes 5 sites. No server setup required.
VITE_CLOUDFLARE_ANALYTICS_TOKEN=

# Sentry Error Tracking (production error monitoring)
# Get DSN from: https://sentry.io → Create project (React) → Copy DSN
# Automatically captures unhandled errors and runtime exceptions
VITE_SENTRY_DSN=

# Umami analytics (optional, if you prefer self-hosted analytics)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
